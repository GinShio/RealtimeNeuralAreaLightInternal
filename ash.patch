+    pub p_dst_size: *mut usize,
+    pub dst_data: DeviceOrHostAddressKHR,
+    pub src_component_type: ComponentTypeKHR,
+    pub dst_component_type: ComponentTypeKHR,
+    pub num_rows: u32,
+    pub num_columns: u32,
+    pub src_layout: CooperativeVectorMatrixLayoutNV,
+    pub src_stride: vk::DeviceSize,
+    pub dst_layout: CooperativeVectorMatrixLayoutNV,
+    pub dst_stride: vk::DeviceSize,
+}
+impl Default for ConvertCooperativeVectorMatrixInfoNV {
+    fn default() -> Self {
+        unsafe {
+            let mut val: Self = std::mem::zeroed();
+            val.s_type = StructureType::CONVERT_COOPERATIVE_VECTOR_MATRIX_INFO_NV;
+            val.p_next = std::ptr::null();
+            val.src_size = 0;
+            val.src_data = DeviceOrHostAddressConstKHR {
+                host_address: std::ptr::null(),
+            };
+            val.p_dst_size = std::ptr::null_mut();
+            val.dst_data = DeviceOrHostAddressKHR {
+                host_address: std::ptr::null_mut(),
+            };
+            val.src_component_type = ComponentTypeKHR::FLOAT16;
+            val.dst_component_type = ComponentTypeKHR::FLOAT16;
+            val.num_rows = 0;
+            val.num_columns = 0;
+            val.src_layout = CooperativeVectorMatrixLayoutNV::RowMajor;
+            val.src_stride = 0;
+            val.dst_layout = CooperativeVectorMatrixLayoutNV::RowMajor;
+            val.dst_stride = 0;
+            val
+        }
+    }
+}
+impl ConvertCooperativeVectorMatrixInfoNV {
+    pub fn num_rows(mut self, rows: u32) -> Self {
+        self.num_rows = rows;
+        self
+    }
+
+    pub fn num_columns(mut self, columns: u32) -> Self {
+        self.num_columns = columns;
+        self
+    }
+
+    pub fn src_component_type(mut self, ty: ComponentTypeKHR) -> Self {
+        self.src_component_type = ty;
