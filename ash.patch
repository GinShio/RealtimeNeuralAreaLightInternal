+        self.src_stride = stride;
+        self
+    }
+
+    pub fn src_size(mut self, size: usize) -> Self {
+        self.src_size = size;
+        self
+    }
+
+    pub fn src_data(mut self, data: DeviceOrHostAddressConstKHR) -> Self {
+        self.src_data = data;
+        self
+    }
+
+    pub fn dst_component_type(mut self, ty: ComponentTypeKHR) -> Self {
+        self.dst_component_type = ty;
+        self
+    }
+
+    pub fn dst_layout(mut self, layout: CooperativeVectorMatrixLayoutNV) -> Self {
+        self.dst_layout = layout;
+        self
+    }
+
+    pub fn dst_stride(mut self, stride: u64) -> Self {
+        self.dst_stride = stride;
+        self
+    }
+
+    pub fn dst_size(mut self, size: *mut usize) -> Self {
+        self.p_dst_size = size;
+        self
+    }
+
+    pub fn dst_data(mut self, data: DeviceOrHostAddressKHR) -> Self {
+        self.dst_data = data;
+        self
+    }
+
+    pub fn p_next(mut self, next: *const c_void) -> Self {
+        self.p_next = next;
+        self
+    }
+
+    pub fn s_type(mut self, s_type: StructureType) -> Self {
+        self.s_type = s_type;
+        self
+    }
+}
